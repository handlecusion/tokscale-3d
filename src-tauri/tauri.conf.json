{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tokscale",
  "version": "0.1.0",
  "identifier": "com.handlecusion.tokscale3d",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://localhost:4061",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tokscale",
        "width": 940,
        "height": 600,
        "minWidth": 640,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "visible": false,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "exceptionDomain": "localhost",
      "dmg": {
        "background": null,
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    },
    "category": "DeveloperTool",
    "shortDescription": "Token usage dashboard for tokscale CLI",
    "longDescription": "Tokscale is a menubar app that visualizes your local tokscale CLI token usage as an interactive 3D contribution graph. Live updates, per-client filters, and customizable menubar title."
  },
  "plugins": {}
}
